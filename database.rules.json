{
  "rules": {
    "productStats": {
      ".read": true,
      "$productId": {
        ".write": true,
        ".validate": "newData.hasChildren()",
        "views": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "purchases": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "adminProducts": {
      ".read": true,
      ".write": "auth != null"
    },
    "categories": {
      ".read": true,
      ".write": "auth != null"
    },
    "subcategories": {
      ".read": true,
      ".write": "auth != null"
    },
    "settings": {
      ".read": true,
      ".write": "auth != null"
    },
    "fileMetadata": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "orders": {
      ".read": "auth != null",
      "$orderId": {
        ".read": true,
        ".write": true
      }
    },
    "referrers": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    ".read": false,
    ".write": false
  }
}
